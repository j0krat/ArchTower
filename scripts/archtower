#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMAND="$1"

if [[ -z "$COMMAND" ]]; then
    echo "ArchTower"
    echo
    echo "Uso:"
    echo "  archtower info"
    echo "  archtower doctor"
    echo "  archtower logs"
    echo "  archtower version"
    echo "  archtower setup"
    exit 0
fi

COMMAND_FILE="$SCRIPT_DIR/commands/${COMMAND}.sh"

if [[ -f "$COMMAND_FILE" ]]; then
    shift
    bash "$COMMAND_FILE" "$@"
else
    echo "Error: comando desconocido: $COMMAND"
    echo
    echo "Uso:"
    echo "  archtower info"
    echo "  archtower doctor"
    echo "  archtower logs"
    echo "  archtower version"
    echo "  archtower setup"
    exit 1
fi
