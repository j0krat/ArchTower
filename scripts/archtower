#!/usr/bin/env bash

set -e

VERSION="0.3.0-alpha"

show_help() {
    echo "ArchTower CLI"
    echo
    echo "Uso:"
    echo "  archtower info"
    echo "  archtower version"
    echo "  archtower help"
    echo "  archtower doctor"
}

case "$1" in
    info)
        echo "=============================="
        echo "       ArchTower Info"
        echo "=============================="
        echo
        fastfetch
        echo
        echo "Dotfiles:"
        git -C "$HOME/dotfiles" log --oneline -1
        ;;

    version)
        echo "ArchTower $VERSION"
        ;;

    help|"")
        show_help
        ;;
	
    doctor)
        echo "ArchTower Doctor"
        echo

        ping -c 1 archlinux.org >/dev/null 2>&1 \
            && echo "✓ Internet: OK" \
            || echo "✗ Internet: sin conexión"

        command -v fastfetch >/dev/null 2>&1 \
            && echo "✓ Fastfetch: instalado" \
            || echo "✗ Fastfetch: no instalado"

        command -v git >/dev/null 2>&1 \
            && echo "✓ Git: instalado" \
            || echo "✗ Git: no instalado"

        nvidia-smi >/dev/null 2>&1 \
            && echo "✓ NVIDIA: OK" \
            || echo "✗ NVIDIA: problema detectado"

        systemctl is-active --quiet NetworkManager \
            && echo "✓ NetworkManager: activo" \
            || echo "✗ NetworkManager: inactivo"

        df -h / | awk 'NR==2 {print "✓ Disco raíz libre: " $4}'
        free -h | awk '/Mem:/ {print "✓ RAM libre: " $7}'
        ;;
    *)
        echo "Error: comando desconocido: $1"
        echo
        show_help
        exit 1
        ;;
esac
